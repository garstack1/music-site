generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  
}

// ============================================
// AUTH & USERS
// ============================================

model User {
  id            String         @id @default(cuid())
  email         String         @unique
  name          String?
  passwordHash  String
  role          UserRole       @default(PUBLIC)
  blocked       Boolean        @default(false)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  publicReviews PublicReview[]
  savedEvents   SavedEvent[]
}

enum UserRole {
  ADMIN
  PUBLIC
}

model SavedEvent {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  eventId   String
  createdAt DateTime @default(now())
  @@unique([userId, eventId])
  @@index([userId])
}


// ============================================
// NEWS
// ============================================

model RssFeed {
  id          String        @id @default(cuid())
  name        String
  url         String        @unique
  active      Boolean       @default(true)
  lastPolled  DateTime?
  createdAt   DateTime      @default(now())
  articles    NewsArticle[]
}

// ============================================
// ORGANISERS IMPORT
// ============================================
model CsvSource {
  id          String    @id @default(cuid())
  name        String
  url         String    @unique
  active      Boolean   @default(true)
  autoPublish Boolean   @default(true)
  lastPolled  DateTime?
  createdAt   DateTime  @default(now())
}

model NewsArticle {
  id          String    @id @default(cuid())
  title       String
  slug        String    @unique
  summary     String?
  sourceUrl   String    @unique
  imageUrl    String?
  featured    Boolean   @default(false)
  hidden      Boolean   @default(false)
  manual      Boolean   @default(false)
  body        String?
  rssFeed     RssFeed?  @relation(fields: [rssFeedId], references: [id])
  rssFeedId   String?
  publishedAt DateTime
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  tags        ArticleTag[]
}

model ArticleTag {
  id        String      @id @default(cuid())
  article   NewsArticle @relation(fields: [articleId], references: [id], onDelete: Cascade)
  articleId String
  genre     Genre       @relation(fields: [genreId], references: [id])
  genreId   String

  @@unique([articleId, genreId])
}

// ============================================
// EVENTS
// ============================================

model Event {
  id            String      @id @default(cuid())
  name          String
  type          EventType
  artist        String?
  venue         String?
  city          String?
  country       String
  date          DateTime
  endDate       DateTime?
  ticketUrl     String?
  affiliateUrl  String?
  description   String?
  imageUrl      String?
  genre         String?
  subGenre      String?
  startTime     String?
  priceMin      Float?
  priceMax      Float?
  priceCurrency String?
  artistWebsite String?
  artistFacebook String?
  artistTwitter  String?
  artistInstagram String?
  artistSpotify  String?
  artistYoutube  String?
  artistTiktok   String?
  source        EventSource
  sourceId      String?
  fingerprint   String?
  latitude      Float?
  longitude     Float?
  active        Boolean     @default(true)
  featured      Boolean     @default(false)
  ticketClicks  TicketClick[]
  savedEvents   SavedEvent[]
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@unique([fingerprint])
  @@index([date])
  @@index([country])
  @@index([type])
}

enum EventType {
  CONCERT
  FESTIVAL
}

enum EventSource {
  TICKETMASTER
  CSV
  MANUAL
}

// ============================================
// TICKETS (Clicks)
// ============================================
model TicketClick {
  id        String   @id @default(cuid())
  eventId   String
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  @@index([eventId])
  @@index([createdAt])
}



// ============================================
// REVIEWS (Admin concert reviews)
// ============================================

model Review {
  id            String         @id @default(cuid())
  slug          String         @unique
  title         String
  artist        String
  venue         String
  city          String?
  eventDate     DateTime
  setlist       String?
  body          String
  coverImage    String?
  status        ReviewStatus   @default(DRAFT)
  publishedAt   DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  photos        ReviewPhoto[]
  publicReviews PublicReview[]
}

enum ReviewStatus {
  DRAFT
  PUBLISHED
}

model ReviewPhoto {
  id        String  @id @default(cuid())
  review    Review  @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  reviewId  String
  url       String
  caption   String?
  sortOrder Int     @default(0)
}

// ============================================
// PUBLIC REVIEWS (user ratings on admin reviews)
// ============================================

model PublicReview {
  id        String   @id @default(cuid())
  review    Review   @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  reviewId  String
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  score     Int
  text      String?
  approved  Boolean  @default(true)
  flagged   Boolean  @default(false)
  createdAt DateTime @default(now())

  @@unique([reviewId, userId])
}

// ============================================
// GENRES
// ============================================

model Genre {
  id       String       @id @default(cuid())
  name     String       @unique
  slug     String       @unique
  articles ArticleTag[]
}

// ============================================
// ADMIN SETTINGS
// ============================================

model SiteSetting {
  id    String @id @default(cuid())
  key   String @unique
  value String
}

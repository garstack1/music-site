generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================
// AUTH & USERS
// ============================================

model User {
  id            String         @id @default(cuid())
  email         String         @unique
  name          String?
  displayName   String?        // Custom display name for user (shown when creating manual articles)
  passwordHash  String
  role          UserRole       @default(PUBLIC)
  blocked       Boolean        @default(false)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  publicReviews PublicReview[]
  savedEvents   SavedEvent[]
  newsArticles  NewsArticle[]  @relation("NewsArticleCreatedBy")
  competitionWins    Competition[]      @relation("CompetitionWinner")
  competitionEntries CompetitionEntry[]
  emailPreferences   EmailPreferences?
}

enum UserRole {
  ADMIN
  PUBLIC
}

// ============================================
// EMAIL PREFERENCES
// ============================================

model EmailPreferences {
  id                String        @id @default(cuid())
  user              User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId            String        @unique
  
  // Email frequency
  frequency         EmailFrequency @default(NONE)
  preferredDay      Int?          // 0-6 for weekly (0=Sunday), 1-28 for monthly
  
  // Content preferences
  includeFeatured   Boolean       @default(true)
  includePresale    Boolean       @default(true)
  includeExclusive  Boolean       @default(true)
  includeCompetitions Boolean     @default(true)
  
  // Tracking
  lastSentAt        DateTime?
  unsubscribedAt    DateTime?
  unsubscribeToken  String        @unique @default(cuid())
  
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  
  @@index([frequency])
  @@index([lastSentAt])
}

enum EmailFrequency {
  NONE
  DAILY
  WEEKLY
  MONTHLY
}

model SavedEvent {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  eventId   String
  createdAt DateTime @default(now())
  @@unique([userId, eventId])
  @@index([userId])
}




// ============================================
// EMAIL MONITORING FOR PR EMAILS
// ============================================
model ApprovedSender {
  id          String   @id @default(cuid())
  name        String
  email       String   @unique
  startMarker String   @default("===")
  endMarker   String   @default("******")
  sourceLabel String?  // Custom label for articles from this sender
  gmailLabel  String?
  active      Boolean  @default(true)
  autoPublish Boolean  @default(false)
  createdAt   DateTime @default(now())
}

model ProcessedEmail {
  id        String   @id @default(cuid())
  messageId String   @unique
  sender    String
  subject   String?
  createdAt DateTime @default(now())
}

// ============================================
// NEWS - RSS FEEDS
// ============================================

model RssFeed {
  id          String        @id @default(cuid())
  name        String
  url         String        @unique
  sourceLabel String?       // Custom label for articles from this feed (e.g., "via NME")
  active      Boolean       @default(true)
  lastPolled  DateTime?
  createdAt   DateTime      @default(now())
  articles    NewsArticle[]
}

// ============================================
// ORGANISERS IMPORT
// ============================================
model CsvSource {
  id          String    @id @default(cuid())
  name        String
  url         String    @unique
  active      Boolean   @default(true)
  autoPublish Boolean   @default(true)
  lastPolled  DateTime?
  createdAt   DateTime  @default(now())
}

model NewsArticle {
  id          String    @id @default(cuid())
  title       String
  slug        String    @unique
  summary     String?
  sourceUrl   String    @unique
  sourceLabel String?   // Custom label for the source (e.g., "via NME", "Press Release", "Email Submission")
  imageUrl    String?
  featured    Boolean   @default(false)
  hidden      Boolean   @default(false)
  manual      Boolean   @default(false)
  body        String?
  rssFeed     RssFeed?  @relation(fields: [rssFeedId], references: [id])
  rssFeedId   String?
  createdBy   User?     @relation("NewsArticleCreatedBy", fields: [createdById], references: [id])
  createdById String?
  publishedAt DateTime
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  tags        ArticleTag[]
}

model ArticleTag {
  id        String      @id @default(cuid())
  article   NewsArticle @relation(fields: [articleId], references: [id], onDelete: Cascade)
  articleId String
  genre     Genre       @relation(fields: [genreId], references: [id])
  genreId   String

  @@unique([articleId, genreId])
}

// ============================================
// EVENTS
// ============================================
model Presale {
  id            String    @id @default(cuid())
  event         Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)
  eventId       String
  name          String
  description   String?
  url           String?
  startDateTime DateTime
  endDateTime   DateTime
  createdAt     DateTime  @default(now())

  @@index([eventId])
}


model Event {
  id            String      @id @default(cuid())
  name          String
  type          EventType
  artist        String?
  venue         String?
  city          String?
  country       String
  date          DateTime
  endDate       DateTime?
  ticketUrl     String?
  affiliateUrl  String?
  description   String?
  imageUrl      String?
  genre         String?
  subGenre      String?
  startTime     String?
  priceMin      Float?
  priceMax      Float?
  priceCurrency String?
  artistWebsite String?
  artistFacebook String?
  artistTwitter  String?
  artistInstagram String?
  artistSpotify  String?
  artistYoutube  String?
  artistTiktok   String?
  source        EventSource
  sourceId      String?
  fingerprint   String?
  latitude      Float?
  longitude     Float?
  active        Boolean     @default(true)
  featured      Boolean     @default(false)
  subscriberOnly Boolean     @default(false)
  soldOut       Boolean     @default(false)
  presales      Presale[]
  ticketClicks  TicketClick[]
  savedEvents   SavedEvent[]
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@unique([fingerprint])
  @@index([date])
  @@index([country])
  @@index([type])
}

enum EventType {
  CONCERT
  FESTIVAL
}

enum EventSource {
  TICKETMASTER
  CSV
  MANUAL
  WEB_SCRAPE
}

// ============================================
// TICKETS (Clicks)
// ============================================
model TicketClick {
  id        String   @id @default(cuid())
  eventId   String
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  @@index([eventId])
  @@index([createdAt])
}


// ============================================
// COMPETITIONS
// ============================================
model Competition {
  id              String             @id @default(cuid())
  title           String
  slug            String             @unique
  description     String
  prize           String
  prizeType       String             @default("TICKETS")
  imageUrl        String?
  rules           String?
  startDate       DateTime
  endDate         DateTime
  maxEntries      Int?
  active          Boolean            @default(true)
  winnerId        String?
  winner          User?              @relation("CompetitionWinner", fields: [winnerId], references: [id])
  winnerPhoto     String?
  winnerComment   String?
  prizeReleased   Boolean            @default(false)
  drawnAt         DateTime?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  entries         CompetitionEntry[]
  @@index([startDate])
  @@index([endDate])
}

model CompetitionEntry {
  id              String      @id @default(cuid())
  competition     Competition @relation(fields: [competitionId], references: [id], onDelete: Cascade)
  competitionId   String
  user            User        @relation(fields: [userId], references: [id])
  userId          String
  agreedToTerms   Boolean     @default(true)
  createdAt       DateTime    @default(now())
  @@unique([competitionId, userId])
}

// ============================================
// REVIEWS (Admin concert reviews)
// ============================================

model Review {
  id            String         @id @default(cuid())
  slug          String         @unique
  title         String
  artist        String
  venue         String
  city          String?
  eventDate     DateTime
  setlist       String?
  body          String
  coverImage    String?
  status        ReviewStatus   @default(DRAFT)
  publishedAt   DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  photos        ReviewPhoto[]
  publicReviews PublicReview[]
}

enum ReviewStatus {
  DRAFT
  PUBLISHED
}

model ReviewPhoto {
  id        String  @id @default(cuid())
  review    Review  @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  reviewId  String
  url       String
  caption   String?
  sortOrder Int     @default(0)
}

// ============================================
// PUBLIC REVIEWS (user ratings on admin reviews)
// ============================================

model PublicReview {
  id        String   @id @default(cuid())
  review    Review   @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  reviewId  String
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  score     Int
  text      String?
  approved  Boolean  @default(true)
  flagged   Boolean  @default(false)
  createdAt DateTime @default(now())

  @@unique([reviewId, userId])
}

// ============================================
// GENRES
// ============================================

model Genre {
  id       String       @id @default(cuid())
  name     String       @unique
  slug     String       @unique
  articles ArticleTag[]
}

// ============================================
// ADMIN SETTINGS
// ============================================

model SiteSetting {
  id    String @id @default(cuid())
  key   String @unique
  value String
}

// ============================================
// TICKETMASTER IMPORT LOGS
// ============================================

model ImportLog {
  id            String    @id @default(cuid())
  type          String    // "ticketmaster_auto", "ticketmaster_manual", "csv", "web_scrape"
  status        String    // "success", "partial", "failed"
  eventsCreated Int       @default(0)
  eventsUpdated Int       @default(0)
  eventsSkipped Int       @default(0)
  errors        String?   // JSON array of error messages
  duration      Int?      // Duration in milliseconds
  triggeredBy   String?   // "cron", "manual", or user email
  details       String?   // Additional details/notes
  createdAt     DateTime  @default(now())

  @@index([type])
  @@index([createdAt])
}

// ============================================
// FESTIVAL SEARCH / WEB SCRAPING
// ============================================

model FestivalSearch {
  id            String    @id @default(cuid())
  name          String                  // Friendly name for this search
  searchQuery   String                  // The search query (e.g., "Ireland festivals 2026")
  region        String?                 // Optional: europe, ireland, uk, etc.
  genre         String?                 // Optional: rock, electronic, etc.
  active        Boolean   @default(true)
  lastSearched  DateTime?
  resultsCount  Int?                    // Number of results from last search
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}
